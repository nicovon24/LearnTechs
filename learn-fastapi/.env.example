# Copiá este archivo a .env y completá los valores reales.
# El .env NUNCA se commitea — está en .gitignore.

# Para desarrollo con docker-compose: usar el nombre del servicio "db", no "localhost".
# "localhost" dentro del container api apunta al container mismo, no al servicio db.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/statsdb

# Para desarrollo local sin Docker (uvicorn directo en la máquina):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/statsdb

# Loguea el SQL generado — solo en desarrollo
DEBUG=true
